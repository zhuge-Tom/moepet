# 本地配置（运行时生成）
config.json
__pycache__/
*.pyc
*.pyo
.venv/
venv/
tools/.cubism_external_token.json

# 可重建的本地 CPU 语音运行环境（不提交仓库）
vendor/gpt_sovits_cpu/.venv/
vendor/gpt_sovits_cpu/python-runtime/
vendor/gpt_sovits_cpu/GPT_SoVITS/pretrained_models/*
!vendor/gpt_sovits_cpu/GPT_SoVITS/pretrained_models/.gitignore

# 本地角色音色权重与参考音频（单文件超过 GitHub 100 MB 限制）
characters/*/voice/models/
characters/*/voice/*.wav
characters/*/voice/*.mp3
characters/*/voice/*.flac
characters/*/voice/*.ogg

# 临时基准、诊断输出
work/

# IDE
.vscode/
.idea/

# 角色资源（自己下载）
